# ============================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================================
PORT=3001
NODE_ENV=development

# Secreto JWT (mínimo 32 caracteres aleatorios)
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_larga_y_segura
JWT_REFRESH_SECRET=otro_secreto_diferente_para_refresh_tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# BASE DE DATOS MySQL
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=emailbuilder
DB_USER=root
DB_PASS=

# Conexiones del pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================================
# REDIS (para colas Bull)
# ============================================================
REDIS_URL=redis://localhost:6379
# Si Redis requiere contraseña:
# REDIS_PASSWORD=tu_password_redis

# ============================================================
# USUARIO ADMINISTRADOR INICIAL
# Se crea automáticamente en la primera migración
# ============================================================
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=CambiaEsto123!
ADMIN_NAME=Administrador

# ============================================================
# URL DE LA APLICACIÓN (para tracking de aperturas y clicks)
# En producción: https://tudominio.com
# En desarrollo: http://localhost:3001
# ============================================================
APP_URL=http://localhost:3001

# ============================================================
# CONFIGURACIÓN DE UPLOADS
# ============================================================
UPLOAD_MAX_SIZE_MB=10
UPLOAD_PATH=./uploads

# ============================================================
# THROTTLING DE ENVÍOS (valores por defecto)
# ============================================================
DEFAULT_EMAILS_PER_MINUTE=20
DEFAULT_EMAILS_PER_HOUR=200
DEFAULT_RETRY_ATTEMPTS=3
DEFAULT_RETRY_DELAY_MS=5000
